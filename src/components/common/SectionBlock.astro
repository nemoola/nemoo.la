---
interface Props {
  id: string;
  number: string;
  title: string;
  variant?: 'default' | 'full';
}

const { id, number, title, variant = 'default' } = Astro.props;
---

<section
  id={id}
  class:list={[
    'mx-auto flex min-h-screen max-w-[1100px] flex-col justify-center gap-16 border-t border-border px-14 pt-24 pb-20 max-[760px]:px-6 max-[760px]:py-16',
    `section-block-${variant}`,
  ]}
>
  <div class="flex shrink-0 items-baseline gap-5">
    <span class="font-mono text-[clamp(36px,5vw,60px)] leading-none font-bold tracking-[-0.03em] text-accent opacity-40">
      {number}
    </span>
    <span class="text-[clamp(36px,5vw,60px)] leading-none font-bold tracking-[-0.03em] text-fg">{title}</span>
  </div>
  <slot />
</section>
