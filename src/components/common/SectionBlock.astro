---
interface Props {
  id: string;
  number: string;
  title: string;
  variant?: 'default' | 'full';
}

const { id, number, title, variant = 'default' } = Astro.props;
---

<section id={id} class:list={['section-block', `section-block-${variant}`]}>
  <div class="section-header">
    <span class="section-num">{number}</span>
    <span class="section-title">{title}</span>
  </div>
  <slot />
</section>

<style>
  .section-block {
    min-height: 100vh;
    max-width: 1100px;
    margin: 0 auto;
    padding: 96px 56px 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 64px;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    flex-shrink: 0;
  }

  .section-num {
    font-family: var(--mono);
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.03em;
    line-height: 1;
    opacity: 0.4;
  }

  .section-title {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  @media (max-width: 760px) {
    .section-block { padding: 64px 24px; }
  }
</style>
