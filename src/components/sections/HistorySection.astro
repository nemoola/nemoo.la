---
import SectionBlock from '../common/SectionBlock.astro';

const timelineItems = [
  {
    date: '2020 / 04',
    title: 'プログラミング開始',
    description: 'コロナで学校が休みになって暇でプログラミングを始めた。',
  },
  {
    date: '2022 / 04',
    title: '茨城県立工業高等学校 入学',
  },
  {
    date: '2025 / 03',
    title: '茨城県立工業高等学校 卒業',
  },
  {
    date: '2025 / 04',
    title: 'xxxx大学 入学',
  },
  {
    date: '2025 / 06',
    title: '株式会社xxxxxx アルバイトとして入社',
    description: 'プログラミングさせてもらってます。',
  },
];
---

<SectionBlock id="history" number="03" title="History">
  <div class="timeline">
    {
      timelineItems.map((item) => (
        <div class="timeline-item">
          <div class="timeline-date-col"><div class="timeline-date">{item.date}</div></div>
          <div class="timeline-center">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-title">{item.title}</div>
            {item.description && <div class="timeline-desc">{item.description}</div>}
          </div>
        </div>
      ))
    }
  </div>
</SectionBlock>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 140px 24px 1fr;
    gap: 0;
    position: relative;
  }

  .timeline-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.1em;
  }

  .timeline-center {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--border);
    background: var(--bg);
    flex-shrink: 0;
    margin-top: 4px;
    position: relative;
    z-index: 1;
    transition: border-color 0.2s, background 0.2s;
  }

  .timeline-item:hover .timeline-dot {
    border-color: var(--accent);
    background: var(--accent);
  }

  .timeline-line {
    flex: 1;
    width: 1px;
    background: var(--border);
    margin-top: 4px;
  }

  .timeline-item:last-child .timeline-line { display: none; }

  .timeline-content {
    padding-left: 20px;
    padding-bottom: 36px;
  }

  .timeline-item:last-child .timeline-content { padding-bottom: 0; }

  .timeline-date-col {
    text-align: right;
    padding-right: 20px;
    padding-top: 3px;
    padding-bottom: 36px;
  }

  .timeline-item:last-child .timeline-date-col { padding-bottom: 0; }

  .timeline-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--fg);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .timeline-desc {
    font-size: 13px;
    color: var(--fg2);
    line-height: 1.7;
  }

  @media (max-width: 760px) {
    .timeline-item { grid-template-columns: 80px 24px 1fr; }
  }
</style>
