---
import SectionBlock from '../common/SectionBlock.astro';

const timelineItems = [
  {
    date: '2020 / 04',
    title: 'プログラミング開始',
    description: 'コロナで学校が休みになり、時間ができたのでプログラミングを始めた。',
  },
  {
    date: '2022 / 04',
    title: '茨城県立xx工業高等学校 入学',
  },
  {
    date: '2025 / 03',
    title: '茨城県立xx工業高等学校 卒業',
  },
  {
    date: '2025 / 04',
    title: 'xxxx大学 入学',
  },
  {
    date: '2025 / 06',
    title: '株式会社xxxxxx アルバイトとして入社',
    description: 'プログラミングをさせてもらっています。',
  },
  {
    date: '2026 / 04',
    title: '株式会社xxxxxx 退職',
    description: '大変お世話になりました。',
  },
];
---

<SectionBlock id="history" number="03" title="History">
  <div class="flex flex-col">
    {
      timelineItems.map((item) => (
        <div class="group grid grid-cols-[140px_24px_1fr] max-[760px]:grid-cols-[80px_24px_1fr]">
          <div class="pr-5 pt-[3px] pb-9 text-right group-last:pb-0">
            <div class="font-mono text-[11px] tracking-[0.1em] text-accent">{item.date}</div>
          </div>
          <div class="flex flex-col items-center">
            <div class="relative z-10 mt-1 size-2.5 shrink-0 rounded-full border-2 border-border bg-bg [transition:border-color_0.2s_ease,background_0.2s_ease] group-hover:border-accent group-hover:bg-accent"></div>
            <div class="mt-1 w-px flex-1 bg-border group-last:hidden"></div>
          </div>
          <div class="pb-9 pl-5 group-last:pb-0">
            <div class="mb-1.5 text-base leading-[1.3] font-semibold text-fg">{item.title}</div>
            {item.description && <div class="text-[13px] leading-[1.7] text-fg-2">{item.description}</div>}
          </div>
        </div>
      ))
    }
  </div>
</SectionBlock>
